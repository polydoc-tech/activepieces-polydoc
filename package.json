{
  "name": "activepieces-polydoc",
  "version": "0.1.1",
  "description": "PolyDoc connector for Activepieces: convert HTML or a URL to PDF, capture screenshots, and generate EU e-invoices (Factur-X / ZUGFeRD).",
  "keywords": [
    "activepieces",
    "activepieces-piece",
    "polydoc",
    "pdf",
    "html-to-pdf",
    "screenshot",
    "e-invoice",
    "factur-x",
    "zugferd"
  ],
  "license": "MIT",
  "homepage": "https://polydoc.tech",
  "author": "PolyDoc <hello@polydoc.tech>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/polydoc-tech/activepieces-polydoc.git"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=18.20"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.lib.json",
    "prepublishOnly": "npm run build",
    "dev": "tsc -p tsconfig.lib.json --watch",
    "lint": "eslint src",
    "lintfix": "eslint src --fix",
    "test": "vitest run test/build-request-body.test.ts",
    "test:integration": "vitest run test/integration.test.ts",
    "scrub:check": "grep -rn $'\\u2014' src README.md examples && echo 'em-dash found' && exit 1 || echo 'no em-dash'"
  },
  "dependencies": {
    "@activepieces/pieces-common": "0.12.4",
    "@activepieces/pieces-framework": "0.31.0",
    "@activepieces/shared": "0.94.0",
    "tslib": "^2.6.2"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "typescript": "^5.5.4",
    "vitest": "^2.1.8"
  }
}
